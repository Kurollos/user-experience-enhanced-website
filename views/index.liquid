<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Milledoni Cadeaus</title>
  <link rel="stylesheet" href="/style.css">
  <script src="/script.js"></script>
</head>

<body>

<header class="site-header">
  <section class="container">
    <a href="/" class="logo">
      <img src="{{ 'milledoni.png' | assets_url }}" alt="Milledoni">
    </a>

    <nav class="main-nav">
      <ul>
        <li><a href="/cadeaus">Cadeaus</a></li>
        <li><a href="/categorieën">Categorieën</a></li>

        <!--  WISHLIST BADGE FIX -->
        <li>
          <a href="/wishlist">
            Wishlist
            {% if wishlistCount > 0 %}
              <span class="badge">{{ wishlistCount }}</span>
            {% endif %}
          </a>
        </li>

      </ul>
    </nav>
  </section>
</header>

<main class="categoriepagina">
  <section class="container">

    <!-- Sidebar -->
    <div class="sidebar">

      <!-- Chatbot -->
      <section class="chatbot">
        <section class="chat-window">
          <p class="message bot">Hallo! Waar kan ik je mee helpen?</p>
          <p class="message user">Ik heb een vraag.</p>
        </section>

        <section class="chat-input">
          <form>
            <input type="text" placeholder="Ik ben op zoek naar een cadeau voor..." />
            <button type="submit"><img src="" alt=""></button>
          </form>
        </section>
      </section>

      <!-- FILTER FORM -->
    <form id="filterForm" action="/" method="get">

  <section class="filter-card">
    <h2>Price range (€)</h2>

    <select name="price">
      <option value="">All</option>
      <option value="10">Under €10</option>
      <option value="20">Under €20</option>
      <option value="50">Under €50</option>
    </select>

  </section>

  <button type="submit">Apply Filters</button>

</form>
    </div>

    <!-- POPUP (BELANGRIJK: buiten loop!) -->
    {% if status == "success" %}
      <div class="popup success"> Gift is saved!</div>
    {% endif %}

    {% if status == "error" %}
      <div class="popup error"> This gift is already saved</div>
    {% endif %}

    <!-- PRODUCTEN -->
    <section class="product-grid">
      {% for product in products %}
        <article class="product-card">

          <section class="product-image">
            <img src="{{ product.img | default: product.image }}" alt="{{ product.name }}">

            <form action="/like" method="POST" class="save-form">
              <input type="hidden" name="product_id" value="{{ product.id }}">

              <button class="save-button" type="submit">
                <img class="save-icon" src="/button.png" alt="save">
              </button>
            </form>
          </section>

          <section class="product-info">
            <h2>{{ product.name }}</h2>
            <p class="prijs">€{{ product.amount }}</p>

            <p class="shop">
              Shop: <a href="{{ product.shop_url }}" target="_blank">{{ product.shop_name }}</a>
            </p>

            <p class="spotter">
              Spotter:
              {% if product.spotter_img %}
                <img src="{{ product.spotter_img }}" alt="{{ product.spotter }}">
              {% endif %}
              {{ product.spotter }}
            </p>

            <a href="/product/{{ product.slug }}" class="button">Bekijk product</a>
          </section>

        </article>
      {% endfor %}
    </section>

  </section>
</main>

<footer>
  <h3>Milledoni</h3>
  <p>Unieke cadeaus voor speciale momenten.</p>

  <h3>Contact</h3>
  <p>Email: info@milledoni.nl</p>

  <h3>Volg ons</h3>
  <p>
    <a href="#">Instagram</a> |
    <a href="#">Facebook</a> |
    <a href="#">TikTok</a>
  </p>

  <p>© 2026 Milledoni. Alle rechten voorbehouden.</p>
</footer>

</body>
</html>